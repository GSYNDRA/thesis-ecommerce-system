@startuml
title Password Recovery Workflow (OTP-Based)
autonumber

skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam ParticipantPadding 20

actor User
participant "Web Frontend" as Frontend
participant "Auth API\n(/api/v1/auth)" as Api
participant "Auth Service" as AuthSvc
database "user" as UserTbl
participant "Email Service" as EmailSvc

== Request OTP ==
User -> Frontend : Forgot password(email)
Frontend -> Api : POST /auth/forgot-password
Api -> AuthSvc : forgotPassword(email)
AuthSvc -> UserTbl : findByEmail(email)

alt Email not found / blocked account
  AuthSvc --> Api : generic response
  Api --> Frontend : generic success message
else Valid account
  AuthSvc -> AuthSvc : generate OTP + expiry\nset attempt counters
  AuthSvc -> UserTbl : save OTP metadata
  AuthSvc -> EmailSvc : send OTP email
  AuthSvc --> Api : OTP sent
  Api --> Frontend : prompt OTP entry
end

== Verify OTP ==
User -> Frontend : Enter OTP
Frontend -> Api : POST /auth/verify-otp
Api -> AuthSvc : verifyOtp(email, otp)
AuthSvc -> UserTbl : load OTP state

alt OTP invalid/expired/too-many-attempts
  AuthSvc --> Api : verification denied
  Api --> Frontend : show OTP error
else OTP valid
  AuthSvc -> AuthSvc : issue short-lived reset token
  AuthSvc --> Api : reset token
  Api --> Frontend : proceed to reset password form
end

== Reset Password ==
User -> Frontend : Submit new password
Frontend -> Api : POST /auth/reset-password\nBearer resetToken
Api -> AuthSvc : resetPassword(resetToken, newPassword)
AuthSvc -> AuthSvc : validate reset token

alt Reset token invalid/expired
  AuthSvc --> Api : reset denied
  Api --> Frontend : require new OTP flow
else Reset token valid
  AuthSvc -> AuthSvc : hash new password
  AuthSvc -> UserTbl : update password + clear OTP/reset state
  AuthSvc --> Api : reset success
  Api --> Frontend : password updated
end

== Optional Resend OTP ==
User -> Frontend : Request resend OTP
Frontend -> Api : POST /auth/resend-otp
Api -> AuthSvc : resendOtp(email)
AuthSvc -> UserTbl : update OTP + cooldown checks
AuthSvc -> EmailSvc : send new OTP
AuthSvc --> Api : resend processed
Api --> Frontend : generic response

@enduml

